<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nelel | Your Retirement in Your Hands</title>
    <link rel="icon" type="image/svg" href="/imgs/nelel.svg">
    <link href="https://fonts.googleapis.com/css2?family=Ubuntu:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css" />
    <style>
        body { font-family: 'Ubuntu', sans-serif; background-color: #f8fafc; color: #1e293b; }
        .navbar-brand { font-weight: 700; letter-spacing: -1px; color: #0f172a !important; display: flex; align-items: center; }
        .navbar-logo { height: 45px; margin-right: 4px; }
        .nav-link { font-weight: 500; color: #64748b !important; font-size: 0.95rem; transition: color 0.2s; }
        .nav-link:hover { color: #0f172a !important; }
        .btn-pill { border-radius: 50rem; padding-left: 1.5rem; padding-right: 1.5rem; font-weight: 500; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fs-3" href="/">
                <img src="/imgs/esquie.png" alt="Nelel" class="navbar-logo"> Nelel
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <% if (locals.user) { %>
                        <li class="nav-item"><a class="nav-link" href="/tracker"><i class="bi bi-receipt me-1"></i> Tracker</a></li>
                        <li class="nav-item"><a class="nav-link" href="/profile">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" href="/profile/edit"><i class="bi bi-person-gear"></i> Profile</a></li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-link text-muted text-decoration-none small fw-bold" href="/logout">Logout</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link px-3" href="/login">Log In</a></li>
                        <li class="nav-item">
                            <a class="btn btn-dark btn-pill px-4 shadow-sm" style="background-color: #0f172a;" href="/signup">Get Started</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
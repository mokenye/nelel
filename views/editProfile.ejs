<%- include('partials/header') -%>
<div class="container py-5">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <!-- Welcome Header -->
      <div class="text-center mb-5">
          <h2 class="fw-bold"><%= user.income ? 'Financial Settings' : 'Initialize Your Roadmap' %></h2>
          <p class="text-muted">Configure the data that powers your Dashboard.</p>
      </div>

      <form action="/profile/editProfile" method="POST" class="card shadow-sm border-0">
          <div class="card-body p-4 p-md-5">

              <!-- Section 1: The Basics (Static Data) -->
              <div class="mb-5">
                  <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-person-badge me-2"></i>Basics</h5>
                  <div class="row g-3">
                      <div class="col-md-4">
                          <label for="age" class="form-label small fw-bold">Current Age</label>
                          <input type="number" class="form-control bg-light" id="age" name="age" value="<%= user.age || '' %>" min="16" max="120" required>
                      </div>
                      <div class="col-md-4">
                          <label for="state" class="form-label small fw-bold">State of Residence</label>
                          <select name="state" class="form-select bg-light" id="state" required>
                            <% states.forEach(state => { %>
                              <option value="<%= state.code %>" <%= user.state === state.code ? 'selected' : '' %>><%= state.name %></option>
                            <% }) %>
                          </select>
                      </div>
                      <div class="col-md-4">
                          <label for="retirementAge" class="form-label small fw-bold">Retirement Target</label>
                          <input type="number" class="form-control bg-light" id="retirementAge" name="retirementAge" value="<%= user.retirementAge || '65' %>" min="18" max="120" required>
                      </div>
                  </div>
              </div>

              <!-- Section 2: The Engine (Financial Data) -->
              <div class="mb-5">
                  <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-bank me-2"></i>Financial Overview</h5>
                  <div class="row g-3">
                      <div class="col-md-6">
                          <label for="income" class="form-label small fw-bold">Annual Gross Income ($)</label>
                          <div class="input-group">
                              <span class="input-group-text">$</span>
                              <input type="number" class="form-control" id="income" name="income" value="<%= user.income || '' %>" min="0" required>
                          </div>
                      </div>
                      <div class="col-md-6">
                          <label for="currentsavings" class="form-label small fw-bold">Current Total Savings ($)</label>
                          <div class="input-group">
                              <span class="input-group-text">$</span>
                              <input type="number" class="form-control" id="currentsavings" name="currentsavings" value="<%= user.currentsavings || '' %>" min="0" required>
                          </div>
                      </div>
                      <div class="col-12">
                          <label for="targetSavingsRate" class="form-label small fw-bold">Target Savings Rate (%)</label>
                          <div class="input-group mb-1">
                              <input type="number" class="form-control" id="targetSavingsRate" name="targetSavingsRate" value="<%= user.targetSavingsRate || 20 %>" min="1" max="100" required>
                              <span class="input-group-text">%</span>
                          </div>
                          <div class="form-text extra-small text-info"><i class="bi bi-info-circle me-1"></i> Most experts recommend 20% for long-term growth.</div>
                      </div>
                  </div>
              </div>

              <!-- Section 3: The Ambitions (Life Goals) -->
              <div class="mb-4">
                  <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-trophy me-2"></i>Life Ambitions</h5>
                  <div id="goals-container">
                    <% if (user.goals && user.goals.length > 0) { %>
                        <% user.goals.forEach(function(goal, index) { %>
                          <div class="input-group mb-2 goal-row">
                            <input type="text" name="goalName" class="form-control" value="<%= goal.name %>" placeholder="e.g. Buy a house">
                            <span class="input-group-text">$</span>
                            <input type="number" name="goalAmount" class="form-control" value="<%= goal.amount %>" placeholder="Amount" min="0">
                            <button type="button" class="btn btn-outline-danger" onclick="this.parentElement.remove()">×</button>
                          </div>
                        <% }); %>
                    <% } %>
                  </div>
                  <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="add-goal-btn">+ Add Life Goal</button>
              </div>

              <!-- Action Buttons -->
              <div class="d-flex align-items-center justify-content-between border-top pt-4 mt-2">
                  <a href="/profile" class="btn btn-link text-muted text-decoration-none small">
                    <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                  </a>
                  <button type="submit" class="btn btn-primary px-4">Save Changes</button>
              </div>
          </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.getElementById('add-goal-btn').addEventListener('click', () => {
    const container = document.getElementById('goals-container');
    const div = document.createElement('div');
    div.className = 'input-group mb-2 goal-row shadow-sm';
    div.innerHTML = `
      <input type="text" name="goalName" class="form-control" placeholder="e.g. Travel Fund">
      <span class="input-group-text">$</span>
      <input type="number" name="goalAmount" class="form-control" placeholder="Target" min="0">
      <button type="button" class="btn btn-outline-danger" onclick="this.parentElement.remove()">×</button>
    `;
    container.appendChild(div);
  });
</script>
<%- include('partials/footer') -%>
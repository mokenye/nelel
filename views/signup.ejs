<%- include('partials/header') -%>

<main class="d-flex flex-column" style="min-height: calc(100vh - 60px);">
  <div class="flex-grow-1 d-flex align-items-center justify-content-center px-3 py-5">
    <div class="w-100" style="max-width: 420px;">

      <h1 class="fw-bold mb-1" style="font-size: 1.5rem; color: #0f172a; letter-spacing: -0.02em;">Create your account</h1>
      <p class="mb-4" style="color: #64748b; font-size: 0.9rem;">Start mapping your financial future</p>

      <!-- Alerts -->
      <% if (locals.messages && locals.messages.errors) { %>
        <% messages.errors.forEach(el => { %>
          <div class="alert border-0 rounded-3 mb-4 py-2 px-3" style="background: #fef2f2; color: #b91c1c; font-size: 0.875rem;">
            <%= el.msg %>
          </div>
        <% }) %>
      <% } %>
      <% if (locals.messages && locals.messages.info) { %>
        <% messages.info.forEach(el => { %>
          <div class="alert border-0 rounded-3 mb-4 py-2 px-3" style="background: #f0fdf9; color: #065f46; font-size: 0.875rem;">
            <%= el.msg %>
          </div>
        <% }) %>
      <% } %>

      <form action="/signup" method="POST">
        <div class="mb-3">
          <label for="userName" class="form-label fw-medium" style="font-size: 0.8rem; color: #374151; letter-spacing: 0.02em;">Name</label>
          <input type="text" class="form-control rounded-3 border-0 py-2 px-3"
            id="userName" name="userName" placeholder="John Doe" autocomplete="name"
            style="background: #f8fafc; font-size: 0.9rem; box-shadow: inset 0 0 0 1px #e2e8f0;">
        </div>
        <div class="mb-3">
          <label for="email" class="form-label fw-medium" style="font-size: 0.8rem; color: #374151; letter-spacing: 0.02em;">Email</label>
          <input type="email" class="form-control rounded-3 border-0 py-2 px-3"
            id="email" name="email" placeholder="you@example.com" autocomplete="email"
            style="background: #f8fafc; font-size: 0.9rem; box-shadow: inset 0 0 0 1px #e2e8f0;">
        </div>
        <div class="mb-3">
          <label for="password" class="form-label fw-medium" style="font-size: 0.8rem; color: #374151; letter-spacing: 0.02em;">Password</label>
          <input type="password" class="form-control rounded-3 border-0 py-2 px-3"
            id="password" name="password" placeholder="••••••••" autocomplete="new-password"
            style="background: #f8fafc; font-size: 0.9rem; box-shadow: inset 0 0 0 1px #e2e8f0;">
        </div>
        <div class="mb-4">
          <label for="confirmPassword" class="form-label fw-medium" style="font-size: 0.8rem; color: #374151; letter-spacing: 0.02em;">Confirm password</label>
          <input type="password" class="form-control rounded-3 border-0 py-2 px-3"
            id="confirmPassword" name="confirmPassword" placeholder="••••••••" autocomplete="new-password"
            style="background: #f8fafc; font-size: 0.9rem; box-shadow: inset 0 0 0 1px #e2e8f0;">
        </div>
        <button type="submit" class="btn w-100 py-2 rounded-3 fw-semibold mb-3"
          style="background: #0f172a; color: #fff; font-size: 0.9rem; letter-spacing: 0.01em; box-shadow: 0 0 20px rgba(16,185,129,0.15), 0 2px 6px rgba(15,23,42,0.2);">
          Create account
        </button>
      </form>

      <div class="text-center mb-3">
        <span class="text-muted" style="font-size: 0.8rem;">or</span>
      </div>

      <a href="/auth/google" class="btn w-100 py-2 rounded-3 fw-semibold mb-4"
        style="background: #fff; color: #0f172a; font-size: 0.9rem; letter-spacing: 0.01em; border: 1px solid #e2e8f0; box-shadow: 0 2px 6px rgba(15,23,42,0.1);">
        <svg width="18" height="18" viewBox="0 0 24 24" class="me-2">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Sign up with Google
      </a>

      <p class="text-center mt-4 mb-0" style="font-size: 0.875rem; color: #94a3b8;">
        Already have an account? <a href="/login" class="text-decoration-none fw-medium" style="color: #10b981;">Sign in</a>
      </p>

    </div>
  </div>
</main>

<%- include('partials/footer') -%>
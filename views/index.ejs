<%- include('partials/header') -%>

<main style="background-color: #ffffff;">
    <!-- Hero Section -->
    <section class="py-5 overflow-hidden">
        <div class="container py-5">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <!-- High-end badge style -->
                    <div class="d-flex align-items-center mb-3">
                        <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle px-3 py-2">
                            2026 Roadmap Engine
                        </span>
                        <small class="ms-3 text-uppercase fw-bold ls-wide text-muted" style="font-size: 0.65rem; letter-spacing: 0.1em;">
                            Now Live
                        </small>
                    </div>

                    <h1 class="display-3 fw-bold mb-4" style="color: #0f172a; letter-spacing: -0.02em; line-height: 1.1;">
                        Take Control of <br><span class="text-primary" style="color: #3b82f6 !important;">Your Future.</span>
                    </h1>
                    
                    <p class="lead text-secondary mb-5" style="line-height: 1.7; font-size: 1.15rem;">
                        Nelel is the intelligent retirement companion designed to help you visualize, track, and achieve your life goals through <span class="text-dark fw-medium">real-time financial projections.</span>
                    </p>

                    <div class="d-flex flex-wrap gap-3">
                        <a href="/signup" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm py-3" style="font-size: 1rem; background-color: #0f172a;">
                            Start Your Roadmap
                        </a>
                        <a href="#features" class="btn btn-link text-decoration-none text-dark fw-bold px-4 py-3">
                            How it Works <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>

                <div class="col-lg-6">
                    <!-- Elegant Abstract Graphic -->
                    <div class="position-relative p-5 rounded-5 shadow-sm" style="background: linear-gradient(145deg, #f8fafc, #ffffff); border: 1px solid #f1f5f9;">
                        <div class="p-4 bg-white rounded-4 shadow-sm border-start border-primary border-4 mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <small class="text-uppercase fw-bold text-muted" style="font-size: 0.65rem;">Projection Accuracy</small>
                                <span class="text-success fw-bold">99.2%</span>
                            </div>
                            <div class="progress" style="height: 6px; background-color: #f1f5f9;">
                                <div class="progress-bar bg-primary" style="width: 85%"></div>
                            </div>
                        </div>
                        <div class="text-center py-4">
                            <i class="bi bi-graph-up text-primary display-4 opacity-50"></i>
                            <h4 class="fw-bold mt-3" style="color: #1e293b;">Data-Driven Future</h4>
                            <p class="text-muted small">Your life goals, mathematically mapped.</p>
                        </div>
                        <!-- Decorative element -->
                        <div class="position-absolute top-0 end-0 p-3 opacity-25">
                            <i class="bi bi-grid-3x3-gap-fill fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-5" style="background-color: #f8fafc;">
        <div class="container py-5">
            <div class="text-center mb-5 pb-3">
                <span class="text-primary text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.2em;">The Platform</span>
                <h2 class="fw-bold display-5 mt-2" style="color: #0f172a;">Why Nelel?</h2>
                <p class="text-muted mx-auto" style="max-width: 500px;">Simple tools for complex financial decisions, designed for the modern investor.</p>
            </div>

            <div class="row g-5">
                <div class="col-md-4">
                    <div class="h-100 p-4 rounded-4 transition-hover bg-white border-0 shadow-sm">
                        <div class="bg-primary-subtle text-primary rounded-3 d-inline-block p-3 mb-4">
                            <i class="bi bi-bullseye fs-3"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Goal Oriented</h5>
                        <p class="text-muted small mb-0" style="line-height: 1.6;">Define exactly what you're saving for, from international travel to early financial independence.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="h-100 p-4 rounded-4 transition-hover bg-white border-0 shadow-sm">
                        <div class="bg-info-subtle text-info rounded-3 d-inline-block p-3 mb-4">
                            <i class="bi bi-people fs-3"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Community Benchmarks</h5>
                        <p class="text-muted small mb-0" style="line-height: 1.6;">Anonymously compare your trajectory with your peers to see where you truly stand.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="h-100 p-4 rounded-4 transition-hover bg-white border-0 shadow-sm">
                        <div class="bg-warning-subtle text-warning rounded-3 d-inline-block p-3 mb-4">
                            <i class="bi bi-lightning-charge fs-3"></i>
                        </div>
                        <h5 class="fw-bold mb-3">PocketCoach™</h5>
                        <p class="text-muted small mb-0" style="line-height: 1.6;">Our intelligent engine suggests immediate adjustments to reach your goals years faster.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') -%>